# Server (18081 matches the panel's Vite proxy; 8080 is often taken locally)
PORT=18081
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=face_detection

# Auth (JWT). When AUTH_ENABLED=true, management routes require an admin token
# (POST /api/admin/login) and device routes require an admin or tenant-user token.
AUTH_ENABLED=true
JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Offline-profile signing. Base64-encoded 32-byte Ed25519 seed. If unset, an
# ephemeral key is generated at startup (logged so you can persist it).
PROFILE_SIGNING_SEED=
